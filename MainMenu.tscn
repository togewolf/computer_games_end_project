[gd_scene format=3]

[ext_resource type="Script" path="res://main_menu.gd" id="1_menu"]
[ext_resource type="Texture2D" path="res://assets/arena_background.png" id="2_mbg"]
[ext_resource type="Texture2D" path="res://assets/wizard.png" id="3_mwiz"]
[ext_resource type="Texture2D" path="res://assets/wizard_agent.png" id="4_mwag"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn"]
bg_color = Color(0.16, 0.18, 0.32, 0.95)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.43, 0.44, 0.52, 1)
corner_radius_top_left = 6
corner_radius_top_right = 6
corner_radius_bottom_right = 6
corner_radius_bottom_left = 6

